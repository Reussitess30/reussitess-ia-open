    result = cache['afrocaraibeen_knowledge']['empire_ashanti']
elif 'empire' in prompt.lower():
    result = cache['afrocaraibeen_knowledge']['empires']
elif 'festival' in prompt.lower():
    result = cache['afrocaraibeen_knowledge']['festivals']
elif 'reseau' in prompt.lower():
    result = cache['afrocaraibeen_knowledge']['reseau']
if 'mali' in prompt.lower():
