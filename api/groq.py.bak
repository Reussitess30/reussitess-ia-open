    result = cache.get('afrocaraibeen_knowledge', {}).get('musiques', '⚠️ Info non disponible')
elif 'mythes' in prompt.lower():
    result = cache.get('afrocaraibeen_knowledge', {}).get('mythes', '⚠️ Info non disponible')
else:

    # --- Vérifier le cache ---
if 'artisanat' in prompt.lower():
    result = cache['afrocaraibeen_knowledge']['artisanat']
elif 'plantes' in prompt.lower():
    result = cache['afrocaraibeen_knowledge']['plantes_medicinales']
elif 'musique' in prompt.lower():
    result = cache['afrocaraibeen_knowledge']['musiques']
