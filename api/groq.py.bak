    result = cache['afrocaraibeen_knowledge']['histoires_resistance']
elif 'biographie' in prompt.lower():
    result = cache['afrocaraibeen_knowledge']['biographies']
elif 'mythes' in prompt.lower():
    result = cache['afrocaraibeen_knowledge']['mythes']
elif 'empire mali' in prompt.lower():
    result = cache['afrocaraibeen_knowledge']['empire_mali']
