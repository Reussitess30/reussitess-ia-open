import json
from pathlib import Path
from urllib.parse import unquote

CACHE_FILE = Path("groq_cache.json")

# --- Charger le cache ---
if CACHE_FILE.exists():
    with open(CACHE_FILE, "r", encoding="utf-8") as f:
        cache = json.load(f)
else:
    cache = {}

def handler(request, response):
    prompt = request.args.get("prompt", "")
    prompt = unquote(prompt)
# --- Réponses locales Afrocaraibeen ---
if 'mali' in prompt.lower():
    result = cache.get('afrocaraibeen_knowledge', {}).get('empire_mali', '⚠️ Info non disponible')
elif 'ashanti' in prompt.lower():
    result = cache.get('afrocaraibeen_knowledge', {}).get('empire_ashanti', '⚠️ Info non disponible')
